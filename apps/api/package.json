{
  "name": "@automesh/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "webhooks": "tsx scripts/webhooks.ts"
  },
  "dependencies": {
    "@automesh/action-plugins": "workspace:*",
    "@automesh/integrations": "workspace:*",
    "@automesh/shared-types": "workspace:*",
    "@automesh/workflow-engine": "workspace:*",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "groq-sdk": "^0.9.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "nanoid": "^5.0.0",
    "pino": "^9.6.0",
    "postgres": "^3.4.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.19.37",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.1.3",
    "smee-client": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
